{
  "name": "@skenion/sdk",
  "version": "0.2.2",
  "description": "TypeScript SDK for Skenion node authoring and runtime clients",
  "type": "module",
  "license": "Apache-2.0",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "ci": "pnpm run build && pnpm run coverage",
    "coverage": "node --test --experimental-test-coverage --test-coverage-lines=100 --test-coverage-functions=100 --test-coverage-branches=100 --test-coverage-include='dist/**/*.js' test/*.test.mjs",
    "test": "node --test test/*.test.mjs"
  },
  "peerDependencies": {
    "@skenion/contracts": "^0.3.0"
  },
  "devDependencies": {
    "@skenion/contracts": "file:.deps/skenion-contracts/packages/ts",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.12.4"
}
